{
  "manifest_version": 3,
  "name": "WebEdit & PDF Wizard",
  "version": "1.0",
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "description": "Edit any website live! Change text, swap images, hide ads with the Magic Eraser, and export custom webpage mockups to PDF instantly.",
  "author": "WebEdit Wizard Team",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "WebEdit Wizard"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
